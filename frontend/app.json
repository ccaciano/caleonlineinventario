{
  "expo": {
    "name": "Inventory Manager",
    "slug": "inventory-manager",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "frontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.marcosmascarenhas.inventorymanager",
      "infoPlist": {
        "NSCameraUsageDescription": "O aplicativo precisa de acesso à câmera para ler códigos de barras dos produtos.",
        "NSPhotoLibraryUsageDescription": "O aplicativo precisa de acesso à galeria para importar arquivos CSV de produtos."
      }
    },
    "android": {
      "package": "com.marcosmascarenhas.inventorymanager",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#007AFF"
      },
      "edgeToEdgeEnabled": true,
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#007AFF"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "O aplicativo precisa de acesso à câmera para ler códigos de barras."
        }
      ],
      [
        "expo-file-system",
        {
          "copyToCacheDirectory": true
        }
      ],
      "expo-sharing",
      "expo-document-picker"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
